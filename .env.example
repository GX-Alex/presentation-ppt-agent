# ─────────────────────────────────────────────────
# General Agent Platform — 环境配置
# 复制为 .env 并填入你的实际值
# ─────────────────────────────────────────────────

# ── LLM 配置 ──
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=your-api-key-here

# 可选: 其他模型 API Key
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# 上下文窗口大小（Token 数）
MODEL_CONTEXT_WINDOW=128000

# ── 数据库 ──
# 一阶段使用 SQLite，无需修改
DATABASE_URL=sqlite+aiosqlite:///data/generalagent.db

# ── CORS ──
# 逗号分隔的允许来源
CORS_ORIGINS=http://localhost:3000

# ── 运行环境 ──
ENV=development

# ── 端口 ──
# 说明: Docker Compose 默认沿用 8000 映射; 本地 `python main.py` + Next.js 开发代理默认使用 8002
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── 外部 API ──
# Pexels 图片搜索（免费，200 请求/小时）
PEXELS_API_KEY=

# Tavily 网络搜索（免费，1000 请求/月）
TAVILY_API_KEY=

# ── Playwright 浏览器池 ──
# 最大并发浏览器标签页数（用于 PDF/PPTX 导出）
PLAYWRIGHT_MAX_PAGES=3

# ── Node.js 环境 ──
NODE_ENV=development
